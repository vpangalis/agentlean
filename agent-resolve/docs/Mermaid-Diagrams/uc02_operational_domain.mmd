sequenceDiagram
    autonumber
    actor User
    participant UI as UI
    participant SR as support_routes.py
    participant EH as entry_handler.py
    participant RH as reasoning_handler.py
    participant G as graph
    participant ON as operational_node
    participant T as tools.py
    participant KSC as knowledge_search_client
    participant CSC as case_search_client
    participant ESC as evidence_search_client
    participant AZS as Azure AI Search
    participant LLM as Azure OpenAI
    participant ORN as operational_reflection_node
    participant OEN as operational_escalation_node
    participant RF as response_formatter

    User->>UI: question + case_id
    UI->>SR: POST /entry/reasoning
    Note over SR: handle_reasoning_entry() L108
    SR->>SR: _dispatch_entry_handler() L82
    SR->>EH: handle_entry(envelope) L84
    EH->>RH: handle_ai_reasoning() L68
    RH->>G: graph.invoke(initial_state) L66
    Note over G: start->context->intent->readiness->router
    Note over G: context_node sets case_status from blob L50
    Note over G: route_intent() -> OPERATIONAL_CASE

    G->>ON: operational_node(state) L31
    Note over ON: _run_operational(state) L36
    ON->>ON: get_llm("reasoning", 0.2) L44

    ON->>T: search_knowledge_base() L47
    Note over T: hybrid_search_knowledge() L289
    T->>KSC: hybrid_search_knowledge() L40
    KSC->>AZS: knowledge_index_v2
    AZS-->>KSC: List[Document]
    KSC-->>T: List[KnowledgeSummary]
    T-->>ON: knowledge_docs

    alt is_new_problem_question() L61
        ON->>LLM: invoke(NEW_PROBLEM_PROMPT) L66
        LLM-->>ON: response_text
        ON->>ON: extract_suggestions() L72
        ON-->>G: operational_draft current_state=No case loaded

    else case_status == closed L86
        Note over ON: condition: case_status==closed only
        Note over ON: and case_id removed (redundant)
        ON->>T: search_similar_cases() L87
        Note over T: hybrid_search_cases() L108
        T->>CSC: hybrid_search_cases() L66
        CSC->>AZS: case_index_v3
        AZS-->>CSC: List[Document]
        CSC-->>T: List[CaseSummary]
        T-->>ON: supporting_cases

        ON->>T: search_evidence() L90
        Note over T: filter: case_id eq case_id
        T->>ESC: search_evidence() L36
        ESC->>AZS: evidence_index_v1
        AZS-->>ESC: List[Document]
        ESC-->>T: List[EvidenceSummary]
        T-->>ON: referenced_evidence

        ON->>ON: format_d_states() L98
        ON->>LLM: invoke(CLOSED_CASE_PROMPT) L107
        LLM-->>ON: response_text
        ON->>ON: extract_suggestions() L113
        ON-->>G: operational_draft current_state=closed

    else case_status == open (active case)
        ON->>T: search_similar_cases() L129
        T->>CSC: hybrid_search_cases() L66
        CSC->>AZS: case_index_v3
        AZS-->>CSC: List[Document]
        CSC-->>T: List[CaseSummary]
        T-->>ON: supporting_cases

        ON->>T: search_evidence() L132
        T->>ESC: search_evidence() L36
        ESC->>AZS: evidence_index_v1
        AZS-->>ESC: List[Document]
        ESC-->>T: List[EvidenceSummary]
        T-->>ON: referenced_evidence

        ON->>ON: format_d_states() L137
        ON->>LLM: invoke(OPERATIONAL_PROMPT) L159
        LLM-->>ON: response_text
        ON->>ON: extract_suggestions() L166
        ON-->>G: operational_draft current_state=open

    else no case_id fallback
        Note over ON: no case loaded, not new-problem
        ON-->>G: operational_draft no case guidance
    end

    G->>ORN: operational_reflection_node(state) L27
    Note over ORN: get_llm("reasoning", 0.0) L55
    ORN->>LLM: llm.with_structured_output(Assessment) L59
    LLM-->>ORN: OperationalReflectionAssessment
    ORN->>ORN: _score(assessment) L119

    alt score >= 0.65
        ORN-->>G: operational_result=draft
    else score < 0.65
        ORN->>LLM: regen_llm.invoke(REGEN_PROMPT) L72
        LLM-->>ORN: improved response
        ORN-->>G: operational_result=regenerated
        G->>OEN: operational_escalation_node() L7
        Note over OEN: model_name=reasoning L9
        Note over OEN: operational_escalated=True L10
        OEN-->>G: operational_result=premium
    end

    G->>RF: response_formatter_node(state) L9
    Note over RF: OPERATIONAL -> operational_result L17
    RF-->>G: final_response

    G-->>RH: graph_result
    RH-->>SR: EntryResponseEnvelope L83
    SR-->>UI: EntryResponseEnvelope
    UI-->>User: answer + chips

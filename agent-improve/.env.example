# Agent Improve — environment variables
# Copy to .env and fill in values. Never commit .env to git.

AZURE_OPENAI_ENDPOINT=https://valuesims-openai-we.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_INTENT_DEPLOYMENT=intent-model
AZURE_OPENAI_OPERATIONAL_DEPLOYMENT=operational-model
AZURE_OPENAI_PREMIUM_DEPLOYMENT=operational-premium
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

AZURE_SEARCH_ENDPOINT=https://valuesims-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your_key_here
AZURE_SEARCH_IMPROVE_CASE_INDEX=improve_case_index
AZURE_SEARCH_IMPROVE_KNOWLEDGE_INDEX=improve_knowledge_index
AZURE_SEARCH_RESOLVE_CASE_INDEX=case_index_v3
AZURE_SEARCH_RESOLVE_KNOWLEDGE_INDEX=knowledge_index_v2
AZURE_SEARCH_RESOLVE_EVIDENCE_INDEX=evidence_index_v1

AZURE_BLOB_CONNECTION_STRING=your_connection_string_here
AZURE_BLOB_CONTAINER_IMPROVE=agent-improve-cases

AGENT_IMPROVE_PORT=8020
GATE_MAX_ATTEMPTS=3
LOG_LEVEL=INFO

LANGSMITH_API_KEY=your_key_here
LANGSMITH_PROJECT=agent-improve
LANGFUSE_PUBLIC_KEY=your_key_here
LANGFUSE_SECRET_KEY=your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
